-- 1. Kullanıcılar
CREATE TABLE kullanicilar (
    kullanici_id SERIAL PRIMARY KEY,
    ad_soyad VARCHAR(100) NOT NULL,
    eposta VARCHAR(150) UNIQUE NOT NULL,
    kayit_tarihi TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- 2. Ürünler (JSONB ve Kurallar)
CREATE TABLE urunler (
    urun_id SERIAL PRIMARY KEY,
    urun_adi VARCHAR(200) NOT NULL,
    fiyat DECIMAL(10,2) NOT NULL CHECK (fiyat > 0),
    stok_miktari INTEGER NOT NULL CHECK (stok_miktari >= 0),
    ozellikler JSONB, -- Renk, İşlemci vb.
    kategori VARCHAR(50)
);

-- 3. Siparişler
CREATE TABLE siparisler (
    siparis_id SERIAL PRIMARY KEY,
    kullanici_id INTEGER REFERENCES kullanicilar(kullanici_id),
    siparis_tarihi TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    durum VARCHAR(20) DEFAULT 'Beklemede' CHECK (durum IN ('Beklemede', 'Kargoda', 'Teslim Edildi', 'İptal'))
);

-- 4. Sipariş Detayları
CREATE TABLE siparis_detaylari (
    siparis_id INTEGER REFERENCES siparisler(siparis_id),
    urun_id INTEGER REFERENCES urunler(urun_id),
    adet INTEGER NOT NULL CHECK (adet > 0),
    birim_fiyat DECIMAL(10,2) NOT NULL,
    PRIMARY KEY (siparis_id, urun_id)
);

-- 5. İndirim Kuponları Tablosu
CREATE TABLE indirim_kuponlari (
    kupon_id SERIAL PRIMARY KEY,
    kupon_kodu VARCHAR(20) UNIQUE NOT NULL,
    indirim_yuzdesi INTEGER CHECK (indirim_yuzdesi > 0 AND indirim_yuzdesi <= 100),
    gecerlilik_tarihi DATE NOT NULL,
    aktif_mi BOOLEAN DEFAULT TRUE
);

-- 6. Ürün Yorumları Tablosu
CREATE TABLE urun_yorumlar (
    yorum_id SERIAL PRIMARY KEY,
    urun_id INTEGER REFERENCES urunler(urun_id),
    kullanici_id INTEGER REFERENCES kullanicilar(kullanici_id),
    puan INTEGER CHECK (puan >= 1 AND puan <= 5), -- 1-5 yıldız arası
    yorum_metni TEXT,
    yorum_tarihi TIMESTAMP DEFAULT CURRENT_TIMESTAMP

);

-- 7. Sosyal Medya Kampanyaları ve Trafik Takibi
CREATE TABLE kampanya_takip (
    takip_id SERIAL PRIMARY KEY,
    siparis_id INTEGER REFERENCES siparisler(siparis_id),
    kaynak VARCHAR(50), -- Instagram, TikTok, Facebook, Google
    kampanya_adi VARCHAR(100), -- Yaz_Indirimi_2026, Influencer_Kadir_Isbirligi
    tiklama_tarihi TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- 8. İadeler Tablosu (Operasyonel Takip)
CREATE TABLE iadeler (
    iade_id SERIAL PRIMARY KEY,
    siparis_id INTEGER REFERENCES siparisler(siparis_id),
    urun_id INTEGER REFERENCES urunler(urun_id),
    iade_nedeni TEXT,
    iade_tarihi TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    iade_durumu VARCHAR(20) DEFAULT 'İncelemede' CHECK (iade_durumu IN ('İncelemede', 'Onaylandı', 'Reddedildi'))
);

-- 9. Stok Hareketleri Tablosu (Lojistik ve Envanter Analizi)
CREATE TABLE stok_hareketleri (
    hareket_id SERIAL PRIMARY KEY,
    urun_id INTEGER REFERENCES urunler(urun_id),
    degisim_miktari INTEGER, -- Örn: -1 (satış), +50 (yeni stok alımı)
    islem_turu VARCHAR(50), -- 'Satış', 'Yeni Stok', 'İade'
    islem_tarihi TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);
